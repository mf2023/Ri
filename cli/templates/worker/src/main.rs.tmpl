// =============================================================================
// Main Entry Point
// =============================================================================

/// Main entry point for the worker service
#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    println!("Starting {{ project_name }} v{{ project_version }}");
    println!("Author: {{ author }}");

    // Load configuration
    let worker_config = load_config();
    let queue_config = QueueConfig::default();
    let device_config = DeviceControlConfig::default();

    // Initialize modules
    println!("Initializing modules...");

    let queue = init_queue(&queue_config);
    let device_control = init_device_control(&device_config);
    let logger = init_logger();

    logger.info("Starting worker service initialization");

    // Create worker state
    let state = Arc::new(WorkerState::new(queue, device_control, logger, worker_config));

    // Print startup information
    println!("Worker ID: {}", state.config.consumer_id);
    println!("Worker count: {}", state.config.worker_count);
    println!("Press Ctrl+C to stop");

    // Run worker
    run_worker(state).await?;

    println!("Worker shutdown complete");

    Ok(())
}
