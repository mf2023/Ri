// =============================================================================
// Worker Implementation
// =============================================================================
// Worker service implementation.

/// Worker statistics
#[derive(Debug, Clone, Default)]
pub struct WorkerStats {
    /// Total tasks processed
    pub tasks_processed: u64,

    /// Successful tasks
    pub tasks_succeeded: u64,

    /// Failed tasks
    pub tasks_failed: u64,

    /// Retried tasks
    pub tasks_retried: u64,
}

/// Application state for worker service
pub struct WorkerState {
    /// Queue module for task consumption
    pub queue: RiQueueModule,

    /// Device control module
    pub device_control: RiDeviceControlModule,

    /// Logger instance
    pub logger: RiLogger,

    /// Worker configuration
    pub config: WorkerConfig,

    /// Worker statistics
    pub stats: Arc<RwLock<WorkerStats>>,
}

impl WorkerState {
    /// Creates a new worker state
    pub fn new(
        queue: RiQueueModule,
        device_control: RiDeviceControlModule,
        logger: RiLogger,
        config: WorkerConfig,
    ) -> Self {
        Self {
            queue,
            device_control,
            logger,
            config,
            stats: Arc::new(RwLock::new(WorkerStats::default())),
        }
    }

    /// Processes a single task
    pub async fn process_task(&self, task: Task) -> TaskResult {
        match task.task_type.as_str() {
            "example" => handle_example_task(task, &self.logger).await,
            "device" => handle_device_task(task, &self.device_control, &self.logger).await,
            _ => {
                self.logger.warn(&format!("Unknown task type: {}", task.task_type));
                TaskResult {
                    task_id: task.id,
                    status: "failed".to_string(),
                    data: None,
                    error: Some(format!("Unknown task type: {}", task.task_type)),
                    completed_at: chrono::Utc::now().to_rfc3339(),
                    duration_ms: 0,
                }
            }
        }
    }

    /// Updates worker statistics
    pub async fn update_stats(&self, result: &TaskResult) {
        let mut stats = self.stats.write().await;
        stats.tasks_processed += 1;

        match result.status.as_str() {
            "success" => stats.tasks_succeeded += 1,
            "failed" => stats.tasks_failed += 1,
            "retry" => stats.tasks_retried += 1,
            _ => {}
        }
    }
}

// =============================================================================
// Server Initialization
// =============================================================================
// Functions for initializing the worker service.

/// Loads configuration from file or environment
fn load_config() -> WorkerConfig {
    WorkerConfig::default()
}

/// Initializes the queue module
fn init_queue(config: &QueueConfig) -> RiQueueModule {
    RiQueueModule::new()
}

/// Initializes the device control module
fn init_device_control(config: &DeviceControlConfig) -> RiDeviceControlModule {
    if !config.enabled {
        return RiDeviceControlModule::new();
    }

    RiDeviceControlModule::new()
}

/// Initializes the logging system
fn init_logger() -> RiLogger {
    let log_config = RiLogConfig::default();
    RiLogger::new(log_config)
}

/// Runs the worker main loop
///
/// Continuously consumes tasks from the queue and processes them.
/// Handles graceful shutdown on SIGTERM and SIGINT signals.
async fn run_worker(state: Arc<WorkerState>) -> Result<(), Box<dyn std::error::Error>> {
    state.logger.info("Worker started, waiting for tasks...");

