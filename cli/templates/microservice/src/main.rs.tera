// =============================================================================
// Main Entry Point
// =============================================================================

/// Main entry point for the microservice
#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    println!("Starting {{ project_name }} v{{ project_version }}");
    println!("Author: {{ author }}");

    // Load configuration
    let service_config = load_config();
    let mesh_config = MeshConfig::default();
    let obs_config = ObservabilityConfig::default();

    // Initialize modules
    println!("Initializing modules...");

    let service_mesh = init_service_mesh(&mesh_config);
    let observability = init_observability(&obs_config);
    let logger = init_logger(&obs_config);
    let tracer = init_tracer(&obs_config);

    logger.info("Starting microservice initialization");

    // Create service state
    let state = Arc::new(ServiceState::new(
        service_mesh,
        observability,
        logger,
        tracer,
        service_config,
    ));

    // Print service information
    println!("Service: {}", state.config.service_name);
    println!("Instance ID: {}", state.config.instance_id);
    println!("Bind address: {}", state.config.bind_address);

    // Register service with mesh
    register_service(&state).await?;

    // Start health server
    println!("Starting health server...");
    start_health_server(state.clone()).await?;

    // Wait for shutdown signal
    println!("Press Ctrl+C to stop");
    tokio::signal::ctrl_c().await?;

    println!("Shutting down service...");

    Ok(())
}
