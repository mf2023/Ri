/// Server configuration parameters
///
/// Defines the network settings and operational parameters for the web server.
/// This configuration can be loaded from YAML files or environment variables.
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ServerConfig {
    /// Network address to bind the server (e.g., "0.0.0.0:8080")
    pub bind_address: String,

    /// Number of worker threads for request handling
    /// Set to 0 for automatic detection based on CPU cores
    pub workers: usize,

    /// Enable TLS/HTTPS support
    pub tls_enabled: bool,

    /// Path to TLS certificate file (PEM format)
    pub tls_cert_path: Option<String>,

    /// Path to TLS private key file (PEM format)
    pub tls_key_path: Option<String>,

    /// Request timeout in seconds
    pub request_timeout_secs: u64,

    /// Maximum request body size in bytes
    pub max_body_size: usize,
}

impl Default for ServerConfig {
    /// Creates a default server configuration with production-ready defaults
    fn default() -> Self {
        Self {
            bind_address: "0.0.0.0:8080".to_string(),
            workers: 0, // Auto-detect based on CPU cores
            tls_enabled: false,
            tls_cert_path: None,
            tls_key_path: None,
            request_timeout_secs: 30,
            max_body_size: 10 * 1024 * 1024, // 10 MB
        }
    }
}

/// Cache configuration parameters
///
/// Defines the caching strategy and backend settings for the cache module.
/// Supports Redis and in-memory caching backends.
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct CacheConfig {
    /// Enable caching functionality
    pub enabled: bool,

    /// Cache backend type: "redis" or "memory"
    pub backend: String,

    /// Redis connection URL (if using Redis backend)
    pub redis_url: Option<String>,

    /// Default TTL for cached items in seconds
    pub default_ttl_secs: u64,

    /// Maximum number of items in memory cache
    pub max_items: usize,
}

impl Default for CacheConfig {
    fn default() -> Self {
        Self {
            enabled: true,
            backend: "memory".to_string(),
            redis_url: None,
            default_ttl_secs: 300, // 5 minutes
            max_items: 10000,
        }
    }
}

/// Authentication configuration parameters
///
/// Defines the authentication method and settings for the auth module.
/// Supports JWT tokens and OAuth2 integration.
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct AuthConfig {
    /// Enable authentication
    pub enabled: bool,

    /// JWT secret key for token signing
    pub jwt_secret: String,

    /// JWT token expiration time in seconds
    pub token_expiry_secs: u64,

    /// JWT issuer identifier
    pub issuer: String,

    /// Enable token refresh mechanism
    pub enable_refresh: bool,
}

impl Default for AuthConfig {
    fn default() -> Self {
        Self {
            enabled: true,
            jwt_secret: "change-this-secret-in-production".to_string(),
            token_expiry_secs: 3600, // 1 hour
            issuer: "{{ project_name }}".to_string(),
            enable_refresh: true,
        }
    }
}

// =============================================================================
// API Response Types
// =============================================================================
// Standard response types for API endpoints.
// These provide consistent response formatting across all endpoints.

/// Standard API response wrapper
///
/// Provides a consistent structure for all API responses, including
/// success/error status, data payload, and metadata.
#[derive(Debug, Serialize, Deserialize)]
pub struct ApiResponse<T> {
    /// Response status: "success" or "error"
    pub status: String,

    /// Response data payload (optional for error responses)
    pub data: Option<T>,

    /// Error message (present only for error responses)
    pub error: Option<String>,

    /// Response timestamp
    pub timestamp: String,
}

impl<T: Serialize> ApiResponse<T> {
    /// Creates a successful response with data
    pub fn success(data: T) -> Self {
        Self {
            status: "success".to_string(),
            data: Some(data),
            error: None,
            timestamp: chrono::Utc::now().to_rfc3339(),
        }
    }

    /// Creates an error response with message
    pub fn error(message: &str) -> Self {
        Self {
            status: "error".to_string(),
            data: None,
            error: Some(message.to_string()),
            timestamp: chrono::Utc::now().to_rfc3339(),
        }
    }
}

/// Health check response data
#[derive(Debug, Serialize, Deserialize)]
pub struct HealthStatus {
    /// Service name
    pub service: String,

    /// Service version
    pub version: String,

    /// Service status: "healthy" or "unhealthy"
    pub status: String,

    /// Uptime in seconds
    pub uptime_secs: u64,
}

