// The main function that initializes and starts the web server.

/// Main entry point for the {{ project_name }} web service
///
/// This function orchestrates the initialization of all Ri modules,
/// sets up the gateway with routes and middleware, and starts the server.
/// It handles graceful shutdown on SIGTERM and SIGINT signals.
///
/// # Panics
/// Panics if any critical initialization step fails
#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    // Print startup banner
    println!("Starting {{ project_name }} v{{ project_version }}");
    println!("Author: {{ author }}");

    // Load configuration
    let server_config = load_config();
    let cache_config = CacheConfig::default();
    let auth_config = AuthConfig::default();

    // Initialize modules
    println!("Initializing modules...");

    let cache = init_cache(&cache_config);
    let auth = init_auth(&auth_config);
    let logger = init_logger();

    // Log startup information
    logger.info("Starting web service initialization");

    // Create application state
    let state = AppState {
        cache,
        auth,
        logger,
        config: server_config.clone(),
    };

    // Setup gateway with routes
    println!("Setting up gateway...");
    let gateway = setup_gateway(state);

    // Parse bind address
    let addr: SocketAddr = server_config.bind_address.parse()
        .expect("Invalid bind address");

    // Start server
    println!("Server listening on {}", addr);
    println!("Press Ctrl+C to stop");

    // TODO: Start the gateway server
    // gateway.serve(addr).await?;

    // Keep the server running
    tokio::signal::ctrl_c().await?;
    println!("Shutting down server...");

    Ok(())
}
